    /// bool 的原子特化.
    // 该特化不提供算术运算与 fetch 类接口.
    template <>
    struct atomic<bool> {
        using value_type = bool;

    private:
        __atomic_base<bool> _base;

    public:
        atomic() noexcept                         = default;
        ~atomic() noexcept                        = default;
        atomic(const atomic&)                     = delete;
        atomic& operator=(const atomic&)          = delete;
        atomic& operator=(const atomic&) volatile = delete;

        constexpr atomic(bool value) noexcept : _base(value) {}

        bool operator=(bool value) noexcept {
            return _base.operator=(value);
        }

        bool operator=(bool value) volatile noexcept {
            return _base.operator=(value);
        }

        operator bool() const noexcept {
            return _base.load();
        }

        operator bool() const volatile noexcept {
            return _base.load();
        }

        bool is_lock_free() const noexcept {
            return _base.is_lock_free();
        }

        bool is_lock_free() const volatile noexcept {
            return _base.is_lock_free();
        }

        static constexpr bool is_always_lock_free = ATOMIC_BOOL_LOCK_FREE == 2;

        void store(bool value,
                   memory_order order = memory_order_seq_cst) noexcept {
            _base.store(value, order);
        }

        void store(bool value, memory_order order =
                                   memory_order_seq_cst) volatile noexcept {
            _base.store(value, order);
        }

        bool load(memory_order order = memory_order_seq_cst) const noexcept {
            return _base.load(order);
        }

        bool load(memory_order order = memory_order_seq_cst) const
            volatile noexcept {
            return _base.load(order);
        }

        bool exchange(bool value,
                      memory_order order = memory_order_seq_cst) noexcept {
            return _base.exchange(value, order);
        }

        bool exchange(bool value, memory_order order =
                                      memory_order_seq_cst) volatile noexcept {
            return _base.exchange(value, order);
        }

        bool compare_exchange_weak(bool& expected, bool desired,
                                   memory_order success_order,
                                   memory_order failure_order) noexcept {
            return _base.compare_exchange_weak(expected, desired, success_order,
                                               failure_order);
        }

        bool compare_exchange_weak(
            bool& expected, bool desired, memory_order success_order,
            memory_order failure_order) volatile noexcept {
            return _base.compare_exchange_weak(expected, desired, success_order,
                                               failure_order);
        }

        bool compare_exchange_weak(
            bool& expected, bool desired,
            memory_order order = memory_order_seq_cst) noexcept {
            return _base.compare_exchange_weak(expected, desired, order);
        }

        bool compare_exchange_weak(
            bool& expected, bool desired,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.compare_exchange_weak(expected, desired, order);
        }

        bool compare_exchange_strong(bool& expected, bool desired,
                                     memory_order success_order,
                                     memory_order failure_order) noexcept {
            return _base.compare_exchange_strong(expected, desired,
                                                 success_order, failure_order);
        }

        bool compare_exchange_strong(
            bool& expected, bool desired, memory_order success_order,
            memory_order failure_order) volatile noexcept {
            return _base.compare_exchange_strong(expected, desired,
                                                 success_order, failure_order);
        }

        bool compare_exchange_strong(
            bool& expected, bool desired,
            memory_order order = memory_order_seq_cst) noexcept {
            return _base.compare_exchange_strong(expected, desired, order);
        }

        bool compare_exchange_strong(
            bool& expected, bool desired,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.compare_exchange_strong(expected, desired, order);
        }
    };

    /**
     *  @brief Generic atomic type, primary class template.
     *
     *  @tparam _Tp  Type to be made atomic, must be trivially copyable.
     */
    template <typename _Tp>
    struct atomic {
        using value_type = _Tp;

    private:
        // Align 1/2/4/8/16-byte types to at least their size.
        static constexpr int _S_min_alignment = (sizeof(_Tp) &
                                                 (sizeof(_Tp) - 1)) ||
                                                        sizeof(_Tp) > 16
                                                    ? 0
                                                    : sizeof(_Tp);

        static constexpr int _S_alignment = _S_min_alignment > alignof(_Tp)
                                                ? _S_min_alignment
                                                : alignof(_Tp);

        alignas(_S_alignment) _Tp _value;

        static_assert(__is_trivially_copyable(_Tp),
                      "std::atomic requires a trivially copyable type");

        static_assert(sizeof(_Tp) > 0,
                      "Incomplete or zero-sized types are not supported");

        // 模板实参不允许带 const / volatile 限定.
        static_assert(
            is_same_v<_Tp, remove_cv_t<_Tp>>,
            "template argument for std::atomic must not be const or volatile");

        static_assert(is_copy_constructible_v<_Tp>);
        static_assert(is_move_constructible_v<_Tp>);
        static_assert(is_copy_assignable_v<_Tp>);
        static_assert(is_move_assignable_v<_Tp>);

    public:
        // 仅当底层类型可默认构造时才启用默认构造函数.
        constexpr atomic() noexcept(is_nothrow_default_constructible_v<_Tp>)
            requires is_default_constructible_v<_Tp>
            : _value() {}

        ~atomic() noexcept                        = default;
        atomic(const atomic&)                     = delete;
        atomic& operator=(const atomic&)          = delete;
        atomic& operator=(const atomic&) volatile = delete;

        constexpr atomic(_Tp value) noexcept : _value(value) {
#if __has_builtin(__builtin_clear_padding)
            if constexpr (__atomic_impl::__maybe_has_padding<_Tp>())
                if (!std::is_constant_evaluated())
                    __builtin_clear_padding(std::__addressof(_value));
#endif
        }

        operator _Tp() const noexcept {
            return load();
        }

        operator _Tp() const volatile noexcept {
            return load();
        }

        _Tp operator=(_Tp value) noexcept {
            store(value);
            return value;
        }

        _Tp operator=(_Tp value) volatile noexcept {
            store(value);
            return value;
        }

        bool is_lock_free() const noexcept {
            // 传入按最小对齐构造的伪地址, 仅用于查询 lock-free 属性.
            return __atomic_is_lock_free(
                sizeof(_value), reinterpret_cast<void*>(-_S_alignment));
        }

        bool is_lock_free() const volatile noexcept {
            // 传入按最小对齐构造的伪地址, 仅用于查询 lock-free 属性.
            return __atomic_is_lock_free(
                sizeof(_value), reinterpret_cast<void*>(-_S_alignment));
        }

        static constexpr bool is_always_lock_free =
            __atomic_always_lock_free(sizeof(_value), 0);

        void store(_Tp value,
                   memory_order order = memory_order_seq_cst) noexcept {
            __atomic_store(std::__addressof(_value),
                           __atomic_impl::__clear_padding(value), int(order));
        }

        void store(_Tp value, memory_order order =
                                  memory_order_seq_cst) volatile noexcept {
            __atomic_store(std::__addressof(_value),
                           __atomic_impl::__clear_padding(value), int(order));
        }

        _Tp load(memory_order order = memory_order_seq_cst) const noexcept {
            alignas(_Tp) unsigned char buf[sizeof(_Tp)];
            _Tp* ptr = reinterpret_cast<_Tp*>(buf);
            __atomic_load(std::__addressof(_value), ptr, int(order));
            return *ptr;
        }

        _Tp load(memory_order order = memory_order_seq_cst) const
            volatile noexcept {
            alignas(_Tp) unsigned char buf[sizeof(_Tp)];
            _Tp* ptr = reinterpret_cast<_Tp*>(buf);
            __atomic_load(std::__addressof(_value), ptr, int(order));
            return *ptr;
        }

        _Tp exchange(_Tp value,
                     memory_order order = memory_order_seq_cst) noexcept {
            alignas(_Tp) unsigned char buf[sizeof(_Tp)];
            _Tp* ptr = reinterpret_cast<_Tp*>(buf);
            __atomic_exchange(std::__addressof(_value),
                              __atomic_impl::__clear_padding(value), ptr,
                              int(order));
            return *ptr;
        }

        _Tp exchange(_Tp value, memory_order order =
                                    memory_order_seq_cst) volatile noexcept {
            alignas(_Tp) unsigned char buf[sizeof(_Tp)];
            _Tp* ptr = reinterpret_cast<_Tp*>(buf);
            __atomic_exchange(std::__addressof(_value),
                              __atomic_impl::__clear_padding(value), ptr,
                              int(order));
            return *ptr;
        }

        bool compare_exchange_weak(_Tp& expected, _Tp value,
                                   memory_order success_order,
                                   memory_order failure_order) noexcept {
            return __atomic_impl::__compare_exchange(
                _value, expected, value, true, success_order, failure_order);
        }

        bool compare_exchange_weak(
            _Tp& expected, _Tp value, memory_order success_order,
            memory_order failure_order) volatile noexcept {
            return __atomic_impl::__compare_exchange(
                _value, expected, value, true, success_order, failure_order);
        }

        bool compare_exchange_weak(
            _Tp& expected, _Tp value,
            memory_order order = memory_order_seq_cst) noexcept {
            return compare_exchange_weak(expected, value, order,
                                         __cmpexch_failure_order(order));
        }

        bool compare_exchange_weak(
            _Tp& expected, _Tp value,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return compare_exchange_weak(expected, value, order,
                                         __cmpexch_failure_order(order));
        }

        bool compare_exchange_strong(_Tp& expected, _Tp value,
                                     memory_order success_order,
                                     memory_order failure_order) noexcept {
            return __atomic_impl::__compare_exchange(
                _value, expected, value, false, success_order, failure_order);
        }

        bool compare_exchange_strong(
            _Tp& expected, _Tp value, memory_order success_order,
            memory_order failure_order) volatile noexcept {
            return __atomic_impl::__compare_exchange(
                _value, expected, value, false, success_order, failure_order);
        }

        bool compare_exchange_strong(
            _Tp& expected, _Tp value,
            memory_order order = memory_order_seq_cst) noexcept {
            return compare_exchange_strong(expected, value, order,
                                           __cmpexch_failure_order(order));
        }

        bool compare_exchange_strong(
            _Tp& expected, _Tp value,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return compare_exchange_strong(expected, value, order,
                                           __cmpexch_failure_order(order));
        }
    };

    /// 指针类型的原子特化.
    template <typename _Tp>
    struct atomic<_Tp*> {
        using value_type      = _Tp*;
        using difference_type = ptrdiff_t;

        using __pointer_type = _Tp*;
        using __base_type    = __atomic_base<_Tp*>;
        __base_type _base;

        atomic() noexcept                         = default;
        ~atomic() noexcept                        = default;
        atomic(const atomic&)                     = delete;
        atomic& operator=(const atomic&)          = delete;
        atomic& operator=(const atomic&) volatile = delete;

        constexpr atomic(__pointer_type pointer) noexcept : _base(pointer) {}

        operator __pointer_type() const noexcept {
            return __pointer_type(_base);
        }

        operator __pointer_type() const volatile noexcept {
            return __pointer_type(_base);
        }

        __pointer_type operator=(__pointer_type pointer) noexcept {
            return _base.operator=(pointer);
        }

        __pointer_type operator=(__pointer_type pointer) volatile noexcept {
            return _base.operator=(pointer);
        }

        __pointer_type operator++(int) noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base++;
        }

        __pointer_type operator++(int) volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base++;
        }

        __pointer_type operator--(int) noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base--;
        }

        __pointer_type operator--(int) volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base--;
        }

        __pointer_type operator++() noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return ++_base;
        }

        __pointer_type operator++() volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return ++_base;
        }

        __pointer_type operator--() noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return --_base;
        }

        __pointer_type operator--() volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return --_base;
        }

        __pointer_type operator+=(ptrdiff_t offset) noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.operator+=(offset);
        }

        __pointer_type operator+=(ptrdiff_t offset) volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.operator+=(offset);
        }

        __pointer_type operator-=(ptrdiff_t offset) noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.operator-=(offset);
        }

        __pointer_type operator-=(ptrdiff_t offset) volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.operator-=(offset);
        }

        bool is_lock_free() const noexcept {
            return _base.is_lock_free();
        }

        bool is_lock_free() const volatile noexcept {
            return _base.is_lock_free();
        }

        static constexpr bool is_always_lock_free =
            ATOMIC_POINTER_LOCK_FREE == 2;

        void store(__pointer_type pointer,
                   memory_order order = memory_order_seq_cst) noexcept {
            return _base.store(pointer, order);
        }

        void store(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.store(pointer, order);
        }

        __pointer_type load(
            memory_order order = memory_order_seq_cst) const noexcept {
            return _base.load(order);
        }

        __pointer_type load(memory_order order = memory_order_seq_cst) const
            volatile noexcept {
            return _base.load(order);
        }

        __pointer_type exchange(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) noexcept {
            return _base.exchange(pointer, order);
        }

        __pointer_type exchange(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.exchange(pointer, order);
        }

        bool compare_exchange_weak(__pointer_type& expected,
                                   __pointer_type desired,
                                   memory_order success_order,
                                   memory_order failure_order) noexcept {
            return _base.compare_exchange_weak(expected, desired, success_order,
                                               failure_order);
        }

        bool compare_exchange_weak(
            __pointer_type& expected, __pointer_type desired,
            memory_order success_order,
            memory_order failure_order) volatile noexcept {
            return _base.compare_exchange_weak(expected, desired, success_order,
                                               failure_order);
        }

        bool compare_exchange_weak(
            __pointer_type& expected, __pointer_type desired,
            memory_order order = memory_order_seq_cst) noexcept {
            return compare_exchange_weak(expected, desired, order,
                                         __cmpexch_failure_order(order));
        }

        bool compare_exchange_weak(
            __pointer_type& expected, __pointer_type desired,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return compare_exchange_weak(expected, desired, order,
                                         __cmpexch_failure_order(order));
        }

        bool compare_exchange_strong(__pointer_type& expected,
                                     __pointer_type desired,
                                     memory_order success_order,
                                     memory_order failure_order) noexcept {
            return _base.compare_exchange_strong(expected, desired,
                                                 success_order, failure_order);
        }

        bool compare_exchange_strong(
            __pointer_type& expected, __pointer_type desired,
            memory_order success_order,
            memory_order failure_order) volatile noexcept {
            return _base.compare_exchange_strong(expected, desired,
                                                 success_order, failure_order);
        }

        bool compare_exchange_strong(
            __pointer_type& expected, __pointer_type desired,
            memory_order order = memory_order_seq_cst) noexcept {
            return _base.compare_exchange_strong(
                expected, desired, order, __cmpexch_failure_order(order));
        }

        bool compare_exchange_strong(
            __pointer_type& expected, __pointer_type desired,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.compare_exchange_strong(
                expected, desired, order, __cmpexch_failure_order(order));
        }

        __pointer_type fetch_add(
            ptrdiff_t offset,
            memory_order order = memory_order_seq_cst) noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.fetch_add(offset, order);
        }

        __pointer_type fetch_add(
            ptrdiff_t offset,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.fetch_add(offset, order);
        }

        __pointer_type fetch_sub(
            ptrdiff_t offset,
            memory_order order = memory_order_seq_cst) noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.fetch_sub(offset, order);
        }

        __pointer_type fetch_sub(
            ptrdiff_t offset,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            static_assert(is_object_v<_Tp>, "pointer to object type");
            return _base.fetch_sub(offset, order);
        }

        __pointer_type fetch_min(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) noexcept {
            return _base.fetch_min(pointer, order);
        }

        __pointer_type fetch_min(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.fetch_min(pointer, order);
        }

        __pointer_type fetch_max(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) noexcept {
            return _base.fetch_max(pointer, order);
        }

        __pointer_type fetch_max(
            __pointer_type pointer,
            memory_order order = memory_order_seq_cst) volatile noexcept {
            return _base.fetch_max(pointer, order);
        }
    };

    /// char 的原子特化.
    template <>
    struct atomic<char> : __atomic_base<char> {
        using __integral_type = char;
        using __base_type     = __atomic_base<char>;

        atomic() noexcept                         = default;
        ~atomic() noexcept                        = default;
        atomic(const atomic&)                     = delete;
        atomic& operator=(const atomic&)          = delete;
        atomic& operator=(const atomic&) volatile = delete;

        constexpr atomic(__integral_type value) noexcept : __base_type(value) {}

        using __base_type::operator __integral_type;
        using __base_type::operator=;

        static constexpr bool is_always_lock_free = ATOMIC_CHAR_LOCK_FREE == 2;
    };

