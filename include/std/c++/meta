        // 静态反射信息类型
        using info = decltype(^^int);

        // 静态反射异常
        // 仅仅是为了符合规范才在此处定义该异常类
        // 实际上在内核环境中并不会被用到
        // 而是直接 panic (见 _THROW 宏定义)
        class exception : public std::exception {
        private:
            string D_what;
            u8string D_u8what;
            info D_from;
            source_location D_where;

        public:
            consteval exception(
                u8string_view what, info from,
                source_location where = source_location::current()) noexcept
                : D_what{U_exception_cvt_from_utf8(what)},
                  D_u8what{what},
                  D_from{from},
                  D_where{where} {}

            consteval exception(
                string_view what, info from,
                source_location where = source_location::current()) noexcept
                : D_what{what},
                  D_u8what{U_exception_cvt_to_utf8(what)},
                  D_from{from},
                  D_where{where} {}

            consteval exception(const exception&) = default;
            consteval exception(exception&&)      = default;

            consteval exception& operator=(const exception&) = default;
            consteval exception& operator=(exception&&)      = default;

            consteval const char* what() const noexcept override {
                return D_what.c_str();
            }

            consteval u8string_view u8what() const noexcept {
                return D_u8what;
            }

            consteval info from() const noexcept {
                return D_from;
            }

            consteval source_location where() const noexcept {
                return D_where;
            }

        private:
            // 由编译器提供具体转换; 转换失败时返回空 string_view.
            template <ranges::input_range RangeType>
            static consteval u8string_view U_exception_cvt_to_utf8(RangeType&&);

            template <ranges::input_range RangeType>
            static consteval string_view U_exception_cvt_from_utf8(RangeType&&);
        };

