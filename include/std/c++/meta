        // [meta.reflection.annotation], annotation reflection
        consteval vector<info> annotations_of(info);
        consteval vector<info> annotations_of_with_type(info, info);

        EXCEPTION_DEPRECATED
        consteval access_context access_context::via(info cls) const {
            if (cls != info{} &&
                (!std::meta::is_type(cls) ||
                 !std::meta::is_class_type(cls) ||
                 !std::meta::is_complete_type(cls))) {
                _THROW(std::meta::exception(
                    u8"via argument other than null or complete class type "
                    "reflection",
                    ^^access_context::via));
            }
            return access_context{D_scope, cls};
        }

    }  // namespace meta

    // define_static_x 系列函数, 将编译期常量提升为具有静态存储期的对象, 以便在运行时使用
    template <ranges::input_range RangeType>
    consteval const ranges::range_value_t<RangeType>* define_static_string(RangeType&& rg) {
        auto str = meta::reflect_constant_string(rg);
        return meta::extract<const ranges::range_value_t<RangeType>*>(str);
    }

    template <ranges::input_range RangeType>
    consteval span<const ranges::range_value_t<RangeType>> define_static_array(RangeType&& rg) {
        using ValueType    = ranges::range_value_t<RangeType>;
        auto arr = meta::reflect_constant_array(rg);
        auto type  = meta::type_of(arr);
        if (meta::is_array_type(type))
            return span<const ValueType>(meta::extract<const ValueType*>(arr), meta::extent(type, 0U));
        else
            return span<const ValueType>();
    }

    template <class _Tp>
    consteval const remove_cvref_t<_Tp>* define_static_object(_Tp&& obj) {
        using ObjType = remove_reference_t<_Tp>;
        if constexpr (meta::is_class_type(^^ObjType)) {
            auto const_obj = meta::reflect_constant(std::forward<_Tp>(obj));
            return std::addressof(meta::extract<const ObjType&>(const_obj));
        } else
            return std::define_static_array(span(std::addressof(obj), 1)).data();
    }
